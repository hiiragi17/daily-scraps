---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { marked } from 'marked';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post: { id: string; body: any; data: any; }) => {
    // customSlugフィールドがあればそれを使用、なければファイルパスから生成
    const slug = post.data.customSlug || post.id.replace(/\.(md|mdx)$/, '');

    // Markdownを手動でHTMLに変換
    const htmlContent = marked.parse(post.body || '');

    return {
      params: { slug: slug },
      props: {
        postData: post.data,
        htmlContent: htmlContent
      }
    };
  });
}

const { postData, htmlContent } = Astro.props;
---

<BlogPost {...(postData ?? {})}>
  <div class="prose" set:html={htmlContent} />
</BlogPost>

<style is:global>
  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: clamp(1.25rem, 3vw, 1.8rem);
    font-weight: bold;
    border-bottom: 2px solid #e5e5e5;
    padding-bottom: 0.5rem;
  }

  .prose h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 600;
  }

  .prose p {
    margin: 1rem 0;
    line-height: 1.7;
  }

  .prose ul, .prose ol {
    margin: 1rem 0;
    padding-left: clamp(1.25rem, 3vw, 2rem);
  }

  .prose li {
    margin: 0.5rem 0;
    line-height: 1.6;
  }

  .prose pre {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: clamp(0.75rem, 2vw, 1rem);
    border-radius: clamp(4px, 1vw, 8px);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: clamp(1rem, 2vw, 1.5rem) 0;
    font-size: clamp(0.78rem, 1.6vw, 0.9em);
  }

  .prose code {
    background: #f4f4f4;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
    word-break: break-word;
  }

  .prose pre code {
    background: none;
    padding: 0;
    color: #d4d4d4;
    word-break: normal;
  }

  .prose blockquote {
    border-left: 4px solid #e5e5e5;
    padding-left: clamp(0.75rem, 2vw, 1rem);
    margin: clamp(1rem, 2vw, 1.5rem) 0;
    font-style: italic;
    color: #666;
    font-size: clamp(0.9rem, 1.8vw, 1rem);
  }

  .prose img {
    max-width: 100%;
    height: auto;
    border-radius: clamp(4px, 1vw, 8px);
    margin: 1rem 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: clamp(1rem, 2vw, 1.5rem) 0;
    font-size: clamp(0.8rem, 1.8vw, 1rem);
  }

  .prose th,
  .prose td {
    border: 1px solid #e5e5e5;
    padding: clamp(0.375rem, 1vw, 0.75rem);
    text-align: left;
  }

  .prose th {
    background: #f9f9f9;
    font-weight: 600;
  }

  /* レスポンシブ対応 - タブレット */
  @media (max-width: 768px) {
    .prose p {
      line-height: 1.75;
    }

    .prose li {
      margin: 0.375rem 0;
    }
  }

  /* レスポンシブ対応 - モバイル */
  @media (max-width: 480px) {
    .prose h2 {
      border-bottom-width: 1px;
      padding-bottom: 0.375rem;
    }

    .prose p {
      line-height: 1.7;
    }

    .prose li {
      margin: 0.25rem 0;
    }

    .prose table {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .prose th,
    .prose td {
      white-space: nowrap;
    }
  }
</style>
