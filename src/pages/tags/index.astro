---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import { getCategory, CATEGORY_ORDER } from '../../data/tagCategories';

const posts = await getCollection('blog');
const allTags = posts.flatMap((post: { data: { tags: any; }; }) => post.data.tags || []);
const tagCounts = allTags.reduce<Record<string, number>>((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1;
  return acc;
}, {});

// カテゴリ別にグルーピング（各カテゴリ内は記事数降順）
const grouped = new Map<string, [string, number][]>();
for (const category of CATEGORY_ORDER) {
  grouped.set(category, []);
}
for (const [tag, count] of Object.entries(tagCounts)) {
  const category = getCategory(tag);
  if (!grouped.has(category)) {
    grouped.set(category, []);
  }
  grouped.get(category)!.push([tag, count]);
}
for (const tags of grouped.values()) {
  tags.sort((a, b) => b[1] - a[1]);
}
// 空のカテゴリを除外
const categories = [...grouped.entries()].filter(([, tags]) => tags.length > 0);
const totalTags = Object.keys(tagCounts).length;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title="タグ一覧" description="すべてのタグをカテゴリ別に表示" />
  </head>
  <body>
    <Header />
    <main>
      <h1>タグ一覧</h1>
      <p class="tag-summary">{totalTags} 個のタグ</p>
      {categories.length === 0 ? (
        <p>タグがまだありません。記事にタグを追加してください。</p>
      ) : (
        <div class="categories">
          {categories.map(([category, tags]) => (
            <section class="category">
              <h2 class="category-title">{category}<span class="category-count">{tags.length}</span></h2>
              <div class="tag-list">
                {tags.map(([tag, count]) => (
                  <a href={`/daily-scraps/tags/${tag}/`} class="tag">
                    #{tag}<span class="count">{count}</span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      )}
      <div class="back-link">
        <a href="/daily-scraps/">← トップに戻る</a>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    padding: 2rem;
    max-width: 70ch;
    margin: 0 auto;
  }

  h1 {
    margin-bottom: 0.5rem;
  }

  .tag-summary {
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .categories {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .category {
    border-left: 3px solid var(--accent, #4f46e5);
    padding-left: 1.25rem;
  }

  .category-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .category-count {
    font-size: 0.75rem;
    font-weight: normal;
    color: #999;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tag {
    display: inline-block;
    padding: 0.35rem 0.8rem;
    background: #f0f0f0;
    border-radius: 2rem;
    text-decoration: none;
    color: #333;
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .tag:hover {
    background: var(--accent, #4f46e5);
    color: white;
  }

  .tag:hover .count {
    background: rgba(255, 255, 255, 0.3);
    color: white;
  }

  .count {
    display: inline-block;
    margin-left: 0.3rem;
    padding: 0.05rem 0.4rem;
    background: #ddd;
    border-radius: 1rem;
    font-size: 0.8em;
    color: #666;
    transition: all 0.2s;
  }

  .back-link {
    margin-top: 3rem;
  }

  .back-link a {
    color: rgb(var(--accent));
    text-decoration: none;
  }

  .back-link a:hover {
    text-decoration: underline;
  }

  /* レスポンシブ対応 */
  @media (max-width: 768px) {
    main {
      padding: 1rem;
    }

    h1 {
      font-size: 1.8rem;
    }

    .categories {
      gap: 1.5rem;
    }

    .category {
      padding-left: 1rem;
    }

    .tag-list {
      gap: 0.5rem;
    }

    .back-link {
      margin-top: 2rem;
    }
  }

  @media (max-width: 480px) {
    main {
      padding: 0.75rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    .tag {
      padding: 0.3rem 0.6rem;
      font-size: 0.85rem;
    }

    .back-link {
      margin-top: 1.5rem;
    }

    .back-link a {
      font-size: 0.9rem;
    }
  }
</style>
