---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, thumbnail, tags = [] } = Astro.props;

// 現在のページのURL
const currentUrl = new URL(Astro.url.pathname, Astro.site).toString();

// X共有用のテキストとURL
const shareText = `${title} | Daily Scraps`;
const xShareUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(currentUrl)}`;

function formatDate(date: Date | string) {
  const d = new Date(date);
  return d.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: clamp(0.75rem, 3vw, 2rem);
      }

      .hero-image {
        width: 100%;
        height: clamp(180px, 30vw, 360px);
        object-fit: cover;
        border-radius: clamp(6px, 1.5vw, 12px);
        margin-bottom: clamp(1rem, 2.5vw, 2rem);
      }

      .article-meta {
        margin-bottom: clamp(1.5rem, 3vw, 2rem);
      }

      .title {
        font-size: clamp(1.4rem, 4vw, 2.5rem);
        margin: 0.75rem 0;
        line-height: 1.3;
        word-break: auto-phrase;
        overflow-wrap: break-word;
      }

      .date-info {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem 1rem;
        color: #666;
        font-size: clamp(0.8rem, 1.8vw, 0.95rem);
        margin-bottom: 0.75rem;
      }

      .date-info time {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
      }

      .updated-label {
        font-size: 0.85em;
        color: #888;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
      }

      .tag {
        padding: 0.25rem 0.75rem;
        background: #f0f0f0;
        border-radius: 1rem;
        text-decoration: none;
        color: #666;
        font-size: clamp(0.75rem, 1.6vw, 0.875rem);
        transition: background-color 0.2s, color 0.2s;
        white-space: nowrap;
      }

      .tag:hover {
        background: var(--accent);
        color: white;
      }

      .prose {
        line-height: 1.8;
        color: #333;
        font-size: clamp(0.875rem, 2vw, 1rem);
      }

      .prose h2 {
        margin-top: 2rem;
        margin-bottom: 1rem;
      }

      /* X共有ボタンのスタイル */
      .share-section {
        margin: clamp(1.5rem, 4vw, 3rem) 0;
        padding: clamp(1rem, 2.5vw, 2rem) 0;
        border-top: 1px solid #e5e5e5;
      }

      .share-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background-color: #000000;
        color: white;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
        font-size: clamp(0.85rem, 1.8vw, 1rem);
        transition: transform 0.2s, opacity 0.2s;
        min-height: 44px;
        box-sizing: border-box;
      }

      .share-button:hover {
        transform: translateY(-2px);
        opacity: 0.9;
      }

      /* タブレット */
      @media (max-width: 768px) {
        .prose {
          line-height: 1.75;
        }

        .share-section {
          text-align: center;
        }
      }

      /* モバイル */
      @media (max-width: 480px) {
        .title {
          margin: 0.5rem 0;
        }

        .tags {
          gap: 0.25rem;
        }

        .tag {
          padding: 0.2rem 0.6rem;
          min-height: 32px;
          display: inline-flex;
          align-items: center;
        }

        .prose {
          line-height: 1.7;
        }

        .share-button {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article data-pagefind-body>
        {thumbnail && (
          <img
            class="hero-image"
            width={1020}
            height={360}
            src={thumbnail}
            alt={title}
          />
        )}
        <div class="article-meta">
          <h1 class="title" data-pagefind-meta="title">{title}</h1>
          <div class="date-info">
            {pubDate && (
              <time datetime={new Date(pubDate).toISOString()}>
                {formatDate(pubDate)}
              </time>
            )}
            {updatedDate && (
              <time datetime={new Date(updatedDate).toISOString()}>
                <span class="updated-label">（更新: {formatDate(updatedDate)}）</span>
              </time>
            )}
          </div>
          {tags && tags.length > 0 && (
            <div class="tags">
              {tags.map((tag: string) => (
                <a href={`/daily-scraps/tags/${tag}/`} class="tag">
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </div>

        <div class="prose">
          <slot />
        </div>

        <!-- X共有ボタン -->
        <div class="share-section">
          <a
            href={xShareUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="share-button"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
            Xで共有
          </a>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
